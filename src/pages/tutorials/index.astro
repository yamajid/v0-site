---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../data/content.ts';

const tutorials = [
  { icon: '🚀', title: 'Getting Started with v0', desc: 'Beginner\'s complete guide: account setup, AI model selection, first prompt, deployment.', tag: 'Beginner', tc: 'var(--ac)', read: '8' },
  { icon: '💡', title: '50 Best v0 Prompts Cheat Sheet', desc: 'Copy-paste prompts for landing pages, dashboards, e-commerce, auth, forms.', tag: 'Prompts', tc: 'var(--pur)', read: '10' },
  { icon: '📦', title: 'Build a Full SaaS Landing Page', desc: 'Hero, features, pricing, testimonials, and CTA — all from one prompt.', tag: 'Project', tc: 'var(--blu)', read: '12' },
  { icon: '📊', title: 'Create an Analytics Dashboard', desc: 'KPI cards, charts, data tables with sorting and filtering.', tag: 'Advanced', tc: 'var(--pur)', read: '15' },
  { icon: '🎨', title: 'Customize v0 Output with Themes', desc: 'Override shadcn/ui variables, create brand-consistent designs.', tag: 'Design', tc: 'var(--org)', read: '6' },
  { icon: '🚢', title: 'Deploy to Production with Vercel', desc: 'Custom domains, environment variables, CI/CD pipeline setup.', tag: 'DevOps', tc: 'var(--ac)', read: '8' },
];
---

<Base title="v0 Tutorials — Learn AI Code Generation Step by Step (2026)" description="Step-by-step Vercel v0 tutorials: getting started, best prompts, building landing pages, dashboards, customization, and production deployment." canonical={SITE+'/tutorials/'}>
  <nav style="border-bottom:1px solid var(--brd);padding:1rem 0">
    <div class="wrap">
      <ol style="list-style:none;display:flex;gap:.5rem;font-size:.8rem;color:var(--mt2)"><li><a href="/" style="color:var(--mt)">Home</a></li><li>›</li><li style="color:var(--tx)">Tutorials</li></ol>
    </div>
  </nav>

  <div class="wrap">
    <header style="text-align:center;padding:3rem 0 2rem">
      <span class="badge b-pur" style="margin-bottom:1rem;display:inline-block">✦ Tutorials</span>
      <h1 style="font-size:clamp(1.75rem,4vw,2.75rem)">Learn v0 Step by Step</h1>
      <p style="color:var(--mt);max-width:560px;margin:.5rem auto 0;font-size:1.05rem">From your first prompt to production deployment.</p>
    </header>

    <div style="display:grid;gap:1.5rem;max-width:800px;margin:0 auto 4rem">
      {tutorials.map((t,i) => (
        <div class="card" style="padding:1.5rem;cursor:default">
          <a href="https://vercel.com/affiliates" target="_blank" rel="noopener sponsored" style="display:flex;gap:1.25rem;color:var(--tx)!important;align-items:center;text-decoration:none">
            <span style="font-size:.85rem;color:var(--mt2);font-weight:900;width:24px">${i+1}.</span>
            <div style="width:48px;height:48px;background:var(--sf3);border-radius:var(--rad-sm);display:flex;align-items:center;justify-content:center;font-size:1.25rem;flex-shrink:0">${t.icon}</div>
            <div style="flex:1">
              <div style="display:flex;gap:.35rem;align-items:center;margin-bottom:.25rem;flex-wrap:wrap">
                <span class="badge" style={`background:${t.tc}22;color:${t.tc}`}>${t.tag}</span>
                <span style="font-size:.7rem;color:var(--mt2)">${t.read} min read</span>
              </div>
              <h3 style="font-size:1.05rem;margin-bottom:.2rem">${t.title}</h3>
              <p style="color:var(--mt);font-size:.85rem;margin:0">${t.desc}</p>
            </div>
            <span style="font-size:1.25rem;color:var(--ac);flex-shrink:0">→</span>
          </a>
        </div>
      ))}
    </div>
  </div>
</Base>
