---
import BaseLayout from '../../layouts/Base.astro';
import { demos, demoCategories, getDemosByCategory } from '../../data/demos.ts';

const SITE = 'https://yamajid.github.io';
const url = `${SITE}/demos/`;

const breadcrumbJSON = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE + '/' },
    { '@type': 'ListItem', position: 2, name: 'Demos', item: url },
  ],
});

const categories = demoCategories.map(cat => ({
  ...cat,
  demos: getDemosByCategory(cat.slug),
}));

const totalDemos = demos.length;
---

<BaseLayout
  title={`Vercel v0 Demos — ${totalDemos}+ Prompt-to-Component Tutorials`}
  description={`Browse ${totalDemos}+ real-world Vercel v0 demonstrations. Copy-paste prompts, step-by-step guides, and deployment instructions for every UI component.`}
  canonical={url}
  jsonLd={breadcrumbJSON}
>
  <section style="padding:4rem 1.5rem;max-width:1100px;margin:0 auto">
    <!-- Header -->
    <header style="margin-bottom:3rem">
      <nav aria-label="Breadcrumb" style="margin-bottom:1.5rem">
        <ol style="list-style:none;display:flex;gap:.5rem;font-size:.8rem;color:var(--mt2,--mt2,var(--mt,#555));flex-wrap:wrap;align-items:center">
          <li><a href="/">Home</a></li><li style="color:var(--mt2,var(--mt,#555))">/</li>
          <li style="color:var(--tx)">Demos</li>
        </ol>
      </nav>
      <h1 style="font-size:clamp(1.5rem,4vw,2.5rem);line-height:1.2;margin-bottom:.5rem">Vercel v0 Demo Library</h1>
      <p style="font-size:1.1rem;color:var(--mt,var(--text-muted,#888));margin-bottom:.5rem">{totalDemos}+ copy-paste prompt tutorials — from hero sections to enterprise dashboards.</p>
      <p style="font-size:.9rem;color:var(--mt2,var(--mt,#555))">Each demo includes the exact prompt, step-by-step instructions, common mistakes, and FAQ.</p>
    </header>

    <!-- Category Sections -->
    {categories.filter(c => c.demos.length > 0).map(cat => (
      <section style="margin-bottom:3rem">
        <h2 style="font-size:1.4rem;margin-bottom:.5rem;display:flex;align-items:center;gap:.5rem">
          <span>{cat.icon} {cat.name}</span>
          <span style="font-size:.8rem;font-weight:400;color:var(--mt2,var(--mt,#555))">({cat.demos.length})</span>
        </h2>
        <p style="font-size:.9rem;color:var(--mt,var(--text-muted,#888));margin-bottom:1rem">{cat.description}</p>

        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1rem">
          {cat.demos.map(demo => (
            <a href={`/demos/${demo.slug}/`} style="display:block;padding:1.25rem;background:var(--sf,var(--surface,#0a0a0a));border:1px solid var(--brd,var(--border,#1a1a1a));border-radius:var(--rad,var(--radius,12px));transition:transform .15s,border-color .15s"
               class="demo-card">
              <p style="font-size:.95rem;font-weight:600;color:var(--tx);margin-bottom:.25rem;line-height:1.4">{demo.title}</p>
              <p style="font-size:.85rem;color:var(--mt,var(--text-muted,#888));line-height:1.5">{demo.desc}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </section>
</BaseLayout>

<style>
  .demo-card:hover {
    transform: translateY(-2px);
    border-color: var(--ac, #10b981);
  }
</style>
